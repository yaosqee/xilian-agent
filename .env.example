# 昔涟 V3.3 · 环境配置
# 复制此文件为 .env 并填入实际的 API Key
# cp .env.example .env

# ═══════════════════════════════════════════════════════
# 必需 · DeepSeek API（对话核心）
# ═══════════════════════════════════════════════════════
# 主 Key（Pro + Flash 对话）
DEEPSEEK_API_KEY=你的apikey
# 备用 Key（可选，Pro 双 Key 轮询 + Flash 调用）
# 不填则 Flash 回退使用主 Key
DEEPSEEK_API_KEY_2=你的apikey

# ═══════════════════════════════════════════════════════
# 推荐 · 嵌入 API（记忆语义检索 + 角色记忆匹配）
# ═══════════════════════════════════════════════════════
# 硅基流动 bge-m3 嵌入（¥0.0007/千tokens，几乎免费）
# 不填则记忆检索降级为时间+重要性排序
EMBED_API_KEY=你的apikey
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3

# ═══════════════════════════════════════════════════════
# 可选 · 工具 API（天气 + 网页搜索）
# ═══════════════════════════════════════════════════════
# 和风天气（query_weather 工具，免费版即可）
# https://dev.qweather.com
# QWEATHER_API_KEY=你的apikey
# QWEATHER_API_HOST=devapi.qweather.com

# 智谱 Web Search（search_web 工具 + 天气 fallback）
# https://open.bigmodel.cn
# ZHIPU_SEARCH_API_KEY=你的apikey

# 备用（当前路由表不引用，保留备查）
# DASHSCOPE_API_KEY=你的apikey

# ═══════════════════════════════════════════════════════
# 可选 · 运行参数（取消注释生效）
# ═══════════════════════════════════════════════════════
# HTTP_PORT=8000
# BIND_HOST=127.0.0.1
# NO_HTTP=1          # 禁用 HTTP 通道，仅终端模式
# FRONTEND_DEV=1     # 前端开发模式（Vite dev server）
