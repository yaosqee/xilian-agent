# 昔涟 V3.3 · 环境配置
# 复制此文件为 .env 并填入实际的 API Key

# DeepSeek API（必需）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_KEY_2=sk-your-backup-key-here

# 嵌入 API（可选，默认用硅基流动 bge-m3）
EMBED_API_KEY=sk-your-embed-key
EMBED_BASE_URL=https://api.siliconflow.cn/v1
EMBED_MODEL=BAAI/bge-m3

# HTTP 服务
HTTP_PORT=8000
BIND_HOST=127.0.0.1
# NO_HTTP=1          # 设为 1 禁用 HTTP 通道
# FRONTEND_DEV=1     # 设为 1 使用前端开发模式（Vite dev server）
